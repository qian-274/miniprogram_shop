page {
  min-height: 100vh;
  color: #1f2b25;
  background: #f6f8f4;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
scroll-view,
swiper,
image,
input,
textarea,
button {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1;
  background: transparent;
}

button::after {
  border: 0;
}

image {
  display: block;
  width: 100%;
  height: 100%;
  background: #dfeee2;
}

.page {
  min-height: 100vh;
  background: #f6f8f4;
}

.with-tab {
  padding-bottom: 144rpx;
}

.page-pad {
  padding: 24rpx 28rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 28rpx 0 18rpx;
}

.section-title {
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #1f2b25;
}

.section-more {
  color: #0f9f43;
  font-size: 24rpx;
  font-weight: 700;
}

.price {
  color: #ef4a45;
  font-weight: 900;
  font-size: 36rpx;
  line-height: 1;
}

.price-small {
  font-size: 22rpx;
  font-weight: 800;
}

.muted {
  color: #6d7a72;
}

.pill {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 14rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
  border-radius: 8rpx;
  background: #ff9f1c;
}

.line-clamp-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.line-clamp-2 {
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  min-height: 300rpx;
  padding: 42rpx 28rpx;
  color: #6d7a72;
  text-align: center;
}

.empty-icon {
  width: 88rpx;
  height: 88rpx;
  display: grid;
  place-items: center;
  color: #0f9f43;
  font-size: 42rpx;
  font-weight: 900;
  border-radius: 16rpx;
  background: #e9f9ed;
}

.empty-title {
  color: #1f2b25;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-copy {
  max-width: 520rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.primary-btn,
.ghost-btn,
.danger-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  padding: 0 30rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.primary-btn {
  color: #fff;
  background: #1ecb3a;
}

.ghost-btn {
  color: #0f9f43;
  background: #e9f9ed;
  border: 1rpx solid rgba(30, 203, 58, 0.28);
}

.danger-btn {
  color: #ef4a45;
  background: #fff5f3;
}

.mini-cart-btn {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
  border-radius: 12rpx;
  background: #1ecb3a;
  box-shadow: 0 10rpx 20rpx rgba(30, 203, 58, 0.24);
}

.tap-card {
  transition: transform 0.18s ease, opacity 0.18s ease;
}

.tap-card:active {
  transform: scale(0.985);
  opacity: 0.86;
}
