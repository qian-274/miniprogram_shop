.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  height: 112rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #e2e8e3;
  box-shadow: 0 -8rpx 28rpx rgba(16, 58, 33, 0.08);
}

.tab-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #9ca8a1;
  font-size: 22rpx;
  font-weight: 700;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca8a1;
  font-size: 34rpx;
  line-height: 1;
  border-radius: 12rpx;
}

.tab-text {
  line-height: 1.1;
}

.tab-item.active {
  color: #ef4a45;
}

.tab-item.active .tab-icon {
  color: #fff;
  background: #1ecb3a;
  box-shadow: 0 8rpx 18rpx rgba(30, 203, 58, 0.26);
}

.tab-item:active {
  opacity: 0.72;
}
