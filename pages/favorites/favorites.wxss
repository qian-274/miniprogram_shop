.favorites-page {
  padding: 24rpx 28rpx 40rpx;
}

.favorite-list {
  display: grid;
  gap: 18rpx;
}

.favorite-item {
  display: grid;
  grid-template-columns: 172rpx 1fr;
  gap: 18rpx;
  min-width: 0;
  padding: 16rpx;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.favorite-image {
  width: 172rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.favorite-copy {
  min-width: 0;
}

.favorite-title {
  color: #1f2b25;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.38;
}

.favorite-desc {
  margin-top: 10rpx;
  color: #6d7a72;
  font-size: 23rpx;
}

.favorite-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 18rpx;
}

.footer-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ghost-mini,
.soldout-btn {
  flex: none;
  height: 52rpx;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  font-size: 23rpx;
  font-weight: 800;
  border-radius: 10rpx;
}

.ghost-mini {
  color: #0f9f43;
  background: #e9f9ed;
}

.soldout-btn {
  color: #8a958d;
  background: #edf2ef;
}

.empty-action {
  width: 260rpx;
  margin-top: 12rpx;
}
