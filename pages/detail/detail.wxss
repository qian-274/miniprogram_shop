.detail-page {
  padding-bottom: 126rpx;
}

.detail-scroll {
  height: calc(100vh - 126rpx);
}

.detail-hero {
  width: 100%;
  height: 520rpx;
}

.detail-card {
  position: relative;
  margin: -28rpx 28rpx 18rpx;
  padding: 24rpx;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.tag-row,
.detail-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.stock {
  color: #0f9f43;
  font-size: 24rpx;
  font-weight: 800;
}

.stock.soldout {
  color: #8a958d;
}

.detail-title {
  margin-top: 18rpx;
  color: #1f2b25;
  font-size: 38rpx;
  line-height: 1.36;
  font-weight: 900;
}

.detail-price-row {
  margin-top: 18rpx;
}

.favorite {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  color: #69756e;
  font-size: 22rpx;
  font-weight: 800;
}

.favorite text:first-child {
  color: #ff9f1c;
  font-size: 40rpx;
  line-height: 1;
}

.favorite.active text:first-child {
  color: #ef4a45;
}

.detail-desc {
  margin-top: 18rpx;
  color: #6d7a72;
  font-size: 26rpx;
  line-height: 1.7;
}

.group-price-band {
  margin: 0 28rpx 18rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border: 1rpx solid #f6d7b7;
  border-radius: 16rpx;
  background: linear-gradient(105deg, #ebffef 0%, #fff3de 100%);
}

.group-price {
  color: #ef4a45;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 900;
}

.group-price text {
  margin-right: 4rpx;
  color: #8d5524;
  font-size: 26rpx;
  font-weight: 900;
}

.group-rule {
  margin-top: 12rpx;
  color: #785f43;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.35;
}

.group-open-btn {
  flex: none;
  min-width: 168rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
  border-radius: 12rpx;
  background: #ef4a45;
  box-shadow: 0 12rpx 24rpx rgba(239, 74, 69, 0.22);
}

.group-panel {
  margin: 0 28rpx 18rpx;
  overflow: hidden;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.group-head {
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 0 24rpx;
  color: #1f2b25;
  font-size: 27rpx;
  font-weight: 900;
  border-bottom: 1rpx solid #edf2ef;
}

.group-head text:last-child {
  flex: none;
  color: #0f9f43;
  font-size: 23rpx;
  font-weight: 800;
}

.group-row {
  display: grid;
  grid-template-columns: 72rpx 1fr 198rpx;
  align-items: center;
  gap: 14rpx;
  min-height: 112rpx;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid #edf2ef;
}

.group-row:last-child {
  border-bottom: 0;
}

.group-row.highlight {
  background: #fff8ea;
}

.group-avatar {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9f1c, #ef4a45);
}

.group-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.group-copy {
  min-width: 0;
}

.group-name {
  overflow: hidden;
  color: #1f2b25;
  font-size: 27rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.group-desc {
  overflow: hidden;
  margin-top: 8rpx;
  color: #6d7a72;
  font-size: 23rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.group-action {
  justify-self: end;
  width: 188rpx;
  height: 58rpx;
  min-height: 0;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  color: #fff;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
  border-radius: 12rpx;
  background: #ef4a45;
}

button.group-action {
  margin: 0;
  padding: 0;
  line-height: 58rpx;
}

.group-action.invite {
  width: 136rpx;
  background: #ff9f1c;
}

.group-action.muted {
  width: 136rpx;
  color: #0f9f43;
  background: #e9f9ed;
}

.group-empty {
  padding: 26rpx 24rpx;
  color: #6d7a72;
  font-size: 25rpx;
  line-height: 1.6;
  background: #fbfcfa;
}

.info-block {
  margin: 0 28rpx 18rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.info-line {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  color: #1f2b25;
  font-size: 26rpx;
  font-weight: 800;
  border-bottom: 1rpx solid #edf2ef;
}

.info-line:last-child {
  border-bottom: 0;
}

.info-line > text:first-child {
  flex: none;
  color: #6d7a72;
  font-weight: 700;
}

.info-line > text:last-child {
  min-width: 0;
  text-align: right;
}

.quantity {
  flex: none;
  display: grid;
  grid-template-columns: 54rpx 62rpx 54rpx;
  align-items: center;
  height: 54rpx;
  overflow: hidden;
  color: #46544b;
  text-align: center;
  border: 1rpx solid #f0b3ad;
  border-radius: 12rpx;
  background: #fff;
}

.quantity-btn {
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ef4a45;
  font-size: 34rpx;
  font-weight: 900;
}

.quantity text {
  font-size: 26rpx;
  font-weight: 900;
}

.block-title {
  color: #1f2b25;
  font-size: 30rpx;
  font-weight: 900;
}

.block-copy {
  margin-top: 12rpx;
  color: #617068;
  font-size: 26rpx;
  line-height: 1.75;
}

.detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 45;
  min-height: 112rpx;
  display: grid;
  grid-template-columns: 104rpx 104rpx 1fr 1fr;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 18rpx calc(12rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #e5ece7;
}

.detail-tool {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  color: #657169;
  font-size: 22rpx;
  font-weight: 800;
}

.tool-icon {
  color: #0f9f43;
  font-size: 34rpx;
  line-height: 1;
}

.footer-btn {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
  border-radius: 12rpx;
}

.footer-btn.cart {
  background: #ff9f1c;
}

.footer-btn.buy {
  background: #1ecb3a;
}

.footer-btn.disabled {
  background: #bdc7c0;
}
