<view class="page address-page">
  <view class="address-card">
    <view class="card-head">
      <view>
        <view class="card-title">默认收货信息</view>
        <view class="card-copy">下单时用于联系、核验和配送确认</view>
      </view>
      <view class="card-mark">址</view>
    </view>

    <view class="form-list">
      <view class="form-row">
        <view class="form-label">联系人</view>
        <input
          class="form-input"
          maxlength="16"
          placeholder="请输入联系人姓名"
          value="{{form.name}}"
          bindinput="onNameInput"
        />
      </view>

      <view class="form-row">
        <view class="form-label">手机号</view>
        <input
          class="form-input"
          type="number"
          maxlength="11"
          placeholder="请输入 11 位手机号"
          value="{{form.phone}}"
          bindinput="onPhoneInput"
        />
      </view>

      <view class="form-block">
        <view class="form-label">收货地址</view>
        <textarea
          class="address-textarea"
          maxlength="80"
          placeholder="请输入小区、楼栋、门牌号等详细地址"
          value="{{form.detail}}"
          bindinput="onDetailInput"
        />
      </view>
    </view>
  </view>

  <view class="address-tip">
    <view class="tip-title">温馨提示</view>
    <view class="tip-copy">社区团购订单仍会展示自提点；这里的地址用于商家备货、异常联系和需要配送时确认。</view>
  </view>

  <view class="save-bar">
    <view class="save-btn" bindtap="saveAddress">保存地址</view>
  </view>
</view>
