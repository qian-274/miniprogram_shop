.search-page {
  padding: 24rpx 28rpx 40rpx;
}

.search-box {
  height: 92rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 18rpx;
  color: #75817a;
  border: 1rpx solid #e5ece7;
  border-radius: 12rpx;
  background: #fff;
}

.search-icon {
  flex: none;
  color: #0f9f43;
  font-size: 34rpx;
  font-weight: 900;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 92rpx;
  color: #1f2b25;
  font-size: 28rpx;
}

.search-button {
  flex: none;
  height: 56rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  border-radius: 10rpx;
  background: #1ecb3a;
}

.result-list {
  display: grid;
  gap: 18rpx;
  margin-top: 22rpx;
}

.result-count {
  color: #6d7a72;
  font-size: 24rpx;
  font-weight: 800;
}

.result-item {
  display: grid;
  grid-template-columns: 170rpx 1fr;
  gap: 18rpx;
  min-width: 0;
  padding: 16rpx;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.result-image {
  width: 170rpx;
  height: 158rpx;
  border-radius: 12rpx;
}

.result-copy {
  min-width: 0;
}

.result-title {
  color: #1f2b25;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.38;
}

.result-desc {
  margin-top: 10rpx;
  color: #6d7a72;
  font-size: 23rpx;
}

.result-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 18rpx;
}

.soldout-btn {
  flex: none;
  height: 52rpx;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  color: #8a958d;
  font-size: 23rpx;
  font-weight: 800;
  border-radius: 10rpx;
  background: #edf2ef;
}

.empty-action {
  width: 260rpx;
  margin-top: 12rpx;
}
