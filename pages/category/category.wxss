.category-page {
  overflow: hidden;
}

.category-layout {
  display: grid;
  grid-template-columns: 184rpx 1fr;
  height: calc(100vh - 112rpx);
  min-height: 0;
  background: #f6f8f4;
}

.category-menu {
  height: 100%;
  background: #edf3ef;
  border-right: 1rpx solid #dfe8e2;
}

.menu-row {
  min-height: 98rpx;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  color: #536157;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.25;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.82);
}

.menu-row.active {
  color: #0f9f43;
  padding-left: 12rpx;
  border-left: 6rpx solid #1ecb3a;
  background: #fff;
}

.category-products {
  height: 100%;
  padding: 24rpx 24rpx 150rpx;
}

.category-banner {
  position: relative;
  height: 166rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
  border-radius: 16rpx;
  background: #d7f2d5;
}

.category-banner-copy {
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  color: #fff;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.36);
}

.banner-name {
  font-size: 34rpx;
  font-weight: 900;
}

.banner-slogan {
  font-size: 23rpx;
  font-weight: 800;
}

.product-list {
  display: grid;
  gap: 18rpx;
}

.category-product {
  display: grid;
  grid-template-columns: 154rpx 1fr;
  gap: 18rpx;
  min-width: 0;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e5ece7;
}

.product-thumb {
  width: 154rpx;
  height: 154rpx;
  border-radius: 16rpx;
}

.product-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 2rpx 0;
}

.product-name {
  color: #1f2b25;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.4;
}

.product-desc {
  margin-top: 8rpx;
  color: #6d7a72;
  font-size: 23rpx;
}

.group-desc-line {
  overflow: hidden;
  margin-top: 8rpx;
  color: #ef4a45;
  font-size: 22rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 18rpx;
}

.soldout-btn {
  flex: none;
  height: 52rpx;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  color: #8a958d;
  font-size: 23rpx;
  font-weight: 800;
  border-radius: 10rpx;
  background: #edf2ef;
}
