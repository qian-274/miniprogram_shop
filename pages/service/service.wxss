.service-page {
  padding: 24rpx 28rpx 40rpx;
}

.service-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: 42rpx 28rpx;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.service-icon {
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 42rpx;
  font-weight: 900;
  border-radius: 18rpx;
  background: #1ecb3a;
}

.service-title {
  color: #1f2b25;
  font-size: 34rpx;
  font-weight: 900;
}

.service-copy {
  max-width: 560rpx;
  color: #6d7a72;
  font-size: 25rpx;
  line-height: 1.6;
  text-align: center;
}

.action-btn {
  margin-top: 20rpx;
}

.faq-card {
  margin-top: 26rpx;
  padding: 26rpx;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.faq-title {
  color: #1f2b25;
  font-size: 30rpx;
  font-weight: 900;
}

.faq-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf2ef;
}

.faq-row:last-child {
  border-bottom: 0;
}

.faq-row text:first-child {
  display: block;
  color: #1f2b25;
  font-size: 27rpx;
  font-weight: 900;
}

.faq-row text:last-child {
  display: block;
  margin-top: 8rpx;
  color: #6d7a72;
  font-size: 24rpx;
  line-height: 1.55;
}
