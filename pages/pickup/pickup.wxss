.pickup-page {
  padding: 24rpx 28rpx 140rpx;
}

.group-tip {
  display: grid;
  grid-template-columns: 62rpx 1fr;
  gap: 16rpx;
  align-items: center;
  padding: 24rpx;
  color: #8e372c;
  border: 1rpx solid rgba(255, 159, 28, 0.32);
  border-radius: 16rpx;
  background: #fff5d9;
}

.tip-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
  border-radius: 16rpx;
  background: #ff9f1c;
}

.tip-title {
  color: #1f2b25;
  font-size: 30rpx;
  font-weight: 900;
}

.tip-copy {
  margin-top: 8rpx;
  color: #8b6d39;
  font-size: 24rpx;
  line-height: 1.5;
}

.pickup-list {
  display: grid;
  gap: 18rpx;
  margin-top: 22rpx;
}

.pickup-option {
  display: grid;
  grid-template-columns: 48rpx 1fr auto;
  gap: 16rpx;
  align-items: center;
  min-width: 0;
  padding: 24rpx;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.pickup-option.selected {
  border-color: rgba(30, 203, 58, 0.55);
  background: #e9f9ed;
}

.pickup-mark {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
  border-radius: 50%;
  background: #bdc7c0;
}

.pickup-option.selected .pickup-mark {
  background: #1ecb3a;
}

.pickup-copy {
  min-width: 0;
}

.pickup-title {
  color: #1f2b25;
  font-size: 29rpx;
  font-weight: 900;
}

.pickup-text {
  margin-top: 8rpx;
  color: #6d7a72;
  font-size: 24rpx;
  line-height: 1.5;
}

.distance {
  color: #0f9f43;
  font-size: 24rpx;
  font-weight: 900;
}

.product-strip {
  display: grid;
  grid-template-columns: 96rpx 1fr;
  gap: 16rpx;
  align-items: center;
  margin-top: 22rpx;
  padding: 18rpx;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.product-strip image {
  width: 96rpx;
  height: 86rpx;
  border-radius: 12rpx;
}

.strip-title {
  color: #1f2b25;
  font-size: 27rpx;
  font-weight: 900;
}

.strip-price {
  margin-top: 8rpx;
  color: #ef4a45;
  font-size: 24rpx;
  font-weight: 900;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 45;
  min-height: 112rpx;
  display: grid;
  grid-template-columns: 1fr 236rpx;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff5f3;
  border-top: 1rpx solid #f2ded9;
}

.submit-total {
  min-width: 0;
  padding-left: 28rpx;
  color: #39463f;
  font-size: 26rpx;
  font-weight: 800;
}

.submit-price {
  color: #1ecb3a;
  font-weight: 900;
}

.submit-btn {
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  background: #1ecb3a;
}
