.owner-settings-page {
  padding: 24rpx 28rpx 150rpx;
}

.settings-hero {
  padding: 28rpx;
  color: #fff;
  border-radius: 16rpx;
  background:
    linear-gradient(135deg, rgba(15, 159, 67, 0.98), rgba(30, 203, 58, 0.9)),
    #1ecb3a;
}

.settings-kicker {
  font-size: 23rpx;
  font-weight: 800;
  opacity: 0.84;
}

.settings-title {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.settings-copy {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  opacity: 0.88;
}

.form-card {
  margin-top: 22rpx;
  overflow: hidden;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.field-row {
  min-height: 112rpx;
  display: grid;
  grid-template-columns: 150rpx 1fr;
  gap: 18rpx;
  align-items: center;
  padding: 0 22rpx;
  border-bottom: 1rpx solid #edf2ef;
}

.field-row.readonly {
  background: #fbfcfa;
}

.field-label {
  color: #1f2b25;
  font-size: 26rpx;
  font-weight: 900;
}

.field-input {
  min-width: 0;
  height: 84rpx;
  color: #1f2b25;
  font-size: 27rpx;
  font-weight: 800;
}

.readonly .field-input {
  color: #7a867e;
}

.field-block {
  padding: 24rpx 22rpx;
}

.notice-input {
  width: 100%;
  min-height: 170rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  color: #1f2b25;
  font-size: 27rpx;
  line-height: 1.5;
  border-radius: 12rpx;
  background: #f6f8f4;
}

.tips-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 1rpx dashed #cfe0d4;
  border-radius: 16rpx;
  background: #fbfdfb;
}

.tips-title {
  color: #1f2b25;
  font-size: 27rpx;
  font-weight: 900;
}

.tips-copy {
  margin-top: 10rpx;
  color: #6d7a72;
  font-size: 24rpx;
  line-height: 1.6;
}

.save-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx 30rpx;
  background: rgba(246, 248, 244, 0.94);
  border-top: 1rpx solid #e5ece7;
}

.save-btn {
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 29rpx;
  font-weight: 900;
  border-radius: 14rpx;
  background: #1ecb3a;
}

.save-btn.disabled {
  opacity: 0.7;
}
