<view class="page orders-page">
  <scroll-view class="status-tabs" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <block wx:for="{{statusTabs}}" wx:key="key">
      <view
        class="status-tab {{activeStatus == item.key ? 'active' : ''}}"
        data-status="{{item.key}}"
        bindtap="selectStatus"
      >
        {{item.name}}
      </view>
    </block>
  </scroll-view>

  <view wx:if="{{orders.length}}" class="orders-list">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card">
        <view class="order-head">
          <text>{{item.id}}</text>
          <text class="status-text">{{item.statusText}}</text>
        </view>

        <view class="order-goods" data-id="{{item.id}}" bindtap="showDetail">
          <view class="goods-thumbs">
            <block wx:for="{{item.items}}" wx:key="productId" wx:for-item="goods">
              <image wx:if="{{index < 2}}" class="goods-thumb" src="{{goods.image}}" mode="aspectFill" />
            </block>
          </view>
          <view class="goods-summary">
            <view class="goods-title line-clamp-1">{{item.items[0].name}}</view>
            <view class="goods-meta">共 {{item.count}} 件 · {{item.pickup}}</view>
          </view>
        </view>

        <view class="order-foot">
          <view>
            <view class="order-time">{{item.time}}</view>
            <view class="order-total">合计 ¥{{item.totalText}}</view>
          </view>
          <view
            class="order-action"
            data-id="{{item.id}}"
            data-status="{{item.status}}"
            bindtap="handleAction"
          >
            {{item.actionText}}
          </view>
        </view>
      </view>
    </block>
  </view>

  <view wx:else class="empty-state">
    <view class="empty-icon">单</view>
    <text class="empty-title">暂无订单</text>
    <text class="empty-copy">当前状态还没有订单，去首页挑选一些新鲜商品吧。</text>
    <view class="primary-btn empty-action" bindtap="goHome">去首页逛逛</view>
  </view>
</view>
