.profile-page {
  padding: 24rpx 28rpx 160rpx;
}

.profile-head {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: 36rpx 24rpx 40rpx;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.avatar {
  width: 150rpx;
  height: 150rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 58rpx;
  font-weight: 900;
  border: 10rpx solid #f4fff7;
  border-radius: 50%;
  background: linear-gradient(135deg, #1ecb3a, #35a7ff);
  box-shadow: 0 18rpx 34rpx rgba(30, 203, 58, 0.22);
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.profile-name {
  color: #1f2b25;
  font-size: 34rpx;
  font-weight: 900;
}

.profile-desc {
  color: #6d7a72;
  font-size: 24rpx;
}

.login-btn {
  width: 260rpx;
  min-height: 72rpx;
  margin-top: 4rpx;
}

.wechat-panel {
  margin-top: 22rpx;
  overflow: hidden;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.panel-head.compact {
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  gap: 8rpx;
  padding: 22rpx 24rpx 18rpx;
}

.panel-note {
  color: #7a867e;
  font-size: 22rpx;
  font-weight: 700;
}

.wechat-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 24rpx;
}

.wechat-row {
  display: grid;
  grid-template-columns: 76rpx 96rpx 1fr;
  gap: 18rpx;
  align-items: center;
  min-height: 96rpx;
}

.nickname-row {
  grid-template-columns: 76rpx 1fr;
}

.form-label {
  color: #1f2b25;
  font-size: 26rpx;
  font-weight: 900;
}

.form-tip {
  min-width: 0;
  color: #7a867e;
  font-size: 24rpx;
  font-weight: 700;
}

.avatar-picker {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  color: #0f9f43;
  font-size: 22rpx;
  font-weight: 900;
  border-radius: 18rpx;
  background: #e9f9ed;
  flex: none;
}

.avatar-picker image {
  width: 100%;
  height: 100%;
}

.nickname-input {
  min-width: 0;
  height: 76rpx;
  padding: 0 18rpx;
  color: #1f2b25;
  font-size: 27rpx;
  font-weight: 800;
  border-radius: 12rpx;
  background: #f6f8f4;
}

.save-profile-btn {
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  border-radius: 12rpx;
  background: #1ecb3a;
}

.order-panel {
  margin-top: 22rpx;
  overflow: hidden;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.panel-head {
  min-height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  color: #1f2b25;
  font-size: 30rpx;
  font-weight: 900;
  border-bottom: 1rpx solid #edf2ef;
}

.panel-link {
  color: #0f9f43;
  font-size: 24rpx;
  font-weight: 800;
}

.order-shortcuts {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  padding: 26rpx 6rpx 28rpx;
}

.order-shortcut {
  position: relative;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  color: #3e4b43;
  font-size: 22rpx;
  font-weight: 800;
}

.status-icon {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f9f43;
  font-size: 28rpx;
  font-weight: 900;
  border-radius: 16rpx;
  background: #e9f9ed;
}

.badge {
  position: absolute;
  top: -6rpx;
  right: 14rpx;
  min-width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
  border: 2rpx solid #fff;
  border-radius: 15rpx;
  background: #ef4a45;
}

.service-list {
  margin-top: 22rpx;
  overflow: hidden;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.owner-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 156rpx;
  padding: 24rpx;
  color: #fff;
  background:
    linear-gradient(135deg, rgba(20, 122, 62, 0.96), rgba(30, 203, 58, 0.9)),
    #0f9f43;
}

.owner-entry-copy {
  min-width: 0;
}

.owner-kicker {
  font-size: 22rpx;
  font-weight: 800;
  opacity: 0.82;
}

.owner-title {
  overflow: hidden;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.owner-desc {
  margin-top: 10rpx;
  font-size: 23rpx;
  font-weight: 700;
  opacity: 0.88;
}

.owner-go {
  flex: none;
  height: 60rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  color: #0f9f43;
  font-size: 24rpx;
  font-weight: 900;
  border-radius: 12rpx;
  background: #fff;
}

.service-row {
  min-height: 104rpx;
  display: grid;
  grid-template-columns: 54rpx 1fr 32rpx;
  align-items: center;
  gap: 16rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #edf2ef;
}

.service-row:last-child {
  border-bottom: 0;
}

.service-row text {
  color: #1f2b25;
  font-size: 28rpx;
  font-weight: 800;
}

.service-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f9f43;
  font-size: 32rpx;
  font-weight: 900;
  border-radius: 12rpx;
  background: #e9f9ed;
}

.service-icon.danger {
  color: #ef4a45;
  background: #fff5f3;
}

.chevron {
  color: #a3aea7 !important;
  font-size: 36rpx !important;
}

.recent-box {
  margin-top: 22rpx;
  padding: 28rpx;
  color: #6d7a72;
  border: 1rpx dashed #cfe0d4;
  border-radius: 16rpx;
  background: #f8fbf7;
}

.recent-title {
  color: #1f2b25;
  font-size: 28rpx;
  font-weight: 900;
}

.recent-copy {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
}
