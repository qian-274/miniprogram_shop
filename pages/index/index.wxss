.home-page {
  background: #f6f8f4;
}

.home-hero {
  padding: 24rpx 28rpx 30rpx;
  color: #fff;
  background:
    linear-gradient(135deg, rgba(30, 203, 58, 0.98), rgba(15, 159, 67, 0.95)),
    #1ecb3a;
}

.hero-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.eyebrow {
  margin-bottom: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  opacity: 0.86;
}

.home-title {
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.18;
}

.pickup-chip {
  flex: none;
  padding: 12rpx 18rpx;
  color: #0f9f43;
  font-size: 24rpx;
  font-weight: 900;
  border-radius: 12rpx;
  background: #fff;
}

.pickup-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.search-box {
  height: 92rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 0 18rpx;
  color: #75817a;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 10rpx 24rpx rgba(16, 58, 33, 0.12);
}

.search-icon {
  flex: none;
  color: #0f9f43;
  font-size: 34rpx;
  font-weight: 900;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 92rpx;
  color: #1f2b25;
  font-size: 28rpx;
}

.search-button {
  flex: none;
  height: 56rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  border-radius: 10rpx;
  background: #ff9f1c;
}

.home-content {
  margin-top: -8rpx;
}

.banner {
  height: 300rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: #d7f2d5;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-copy {
  position: absolute;
  left: 24rpx;
  top: 28rpx;
  width: 330rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 20rpx;
  color: #1f2b25;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.86);
}

.banner-title {
  color: #0f9f43;
  font-size: 38rpx;
  line-height: 1.12;
  font-weight: 900;
}

.banner-subtitle {
  color: #d94f26;
  font-size: 24rpx;
  font-weight: 800;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18rpx 10rpx;
  margin-top: 24rpx;
  padding: 8rpx 0 4rpx;
}

.cat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.cat-icon {
  width: 84rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f9f43;
  font-size: 32rpx;
  font-weight: 900;
  border: 1rpx solid rgba(15, 159, 67, 0.14);
  border-radius: 16rpx;
  background: #e9f9ed;
}

.cat-name {
  max-width: 136rpx;
  color: #34423a;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.product-card {
  overflow: hidden;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.product-image-wrap {
  position: relative;
  height: 184rpx;
}

.product-tag {
  position: absolute;
  top: 14rpx;
  left: 14rpx;
}

.product-body {
  padding: 16rpx;
}

.product-name {
  min-height: 76rpx;
  color: #1f2b25;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.42;
}

.product-meta {
  margin-top: 8rpx;
  color: #6d7a72;
  font-size: 22rpx;
}

.group-price-line {
  overflow: hidden;
  margin-top: 10rpx;
  color: #ef4a45;
  font-size: 22rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 16rpx;
}

.wide-list {
  display: grid;
  gap: 18rpx;
}

.wide-item {
  display: grid;
  grid-template-columns: 158rpx 1fr 58rpx;
  gap: 18rpx;
  align-items: center;
  min-width: 0;
  padding: 16rpx;
  border: 1rpx solid #e5ece7;
  border-radius: 16rpx;
  background: #fff;
}

.wide-image {
  width: 158rpx;
  height: 132rpx;
  border-radius: 12rpx;
}

.wide-copy {
  min-width: 0;
}

.wide-title {
  color: #1f2b25;
  font-size: 29rpx;
  font-weight: 900;
}

.wide-desc {
  margin-top: 10rpx;
  color: #6d7a72;
  font-size: 23rpx;
}

.wide-price-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.wide-reason {
  min-width: 0;
  color: #0f9f43;
  font-size: 22rpx;
  font-weight: 800;
}
